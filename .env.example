# ==========================================
# 山影知道 | MOUNTAIN Music 环境变量
# ==========================================

# --- 数据库 ---
# 本地开发（SQLite）
DATABASE_URL="file:./dev.db"

# 部署（Supabase PostgreSQL）
DATABASE_URL="postgresql://postgres:密码@db.lyjpdfmefvayyzngetpw.supabase.co:5432/postgres"

# --- JWT / NextAuth ---
JWT_SECRET="请替换为随机字符串"
NEXTAUTH_SECRET="请替换为随机字符串"

# --- 站点 URL ---
# 本地开发
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Railway 部署
# NEXT_PUBLIC_SITE_URL="https://你的railway域名.railway.app"

# --- 管理员账户 ---
ADMIN_EMAIL="admin@mountainmusic.com"
ADMIN_PASSWORD="admin123456"

# --- 文件上传 ---
# 本地开发：文件存到 public/uploads/，可通过 /api/uploads/ 或静态文件访问
UPLOAD_DIR="public/uploads"
#
# Railway 部署时请改为容器内可写的临时目录（构建后的 public/ 是只读的）：
# UPLOAD_DIR="/tmp/uploads"
