# ==========================================
# 山影知道 | MOUNTAIN Music 环境变量
# ==========================================

# --- 数据库 ---
# 本地开发（SQLite）
# DATABASE_URL="file:./dev.db"

# Railway 部署（PostgreSQL）— Railway 会自动设置
# DATABASE_URL="postgresql://..."

# --- JWT ---
JWT_SECRET="请替换为随机字符串"

# --- 站点 URL ---
# 本地开发
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Railway 部署（Railway 自动设置）
# NEXT_PUBLIC_SITE_URL="https://你的域名.railway.app"

# --- 管理员账户（用于 db:seed）---
ADMIN_EMAIL="admin@mountainmusic.com"
ADMIN_PASSWORD="admin123456"

# --- 文件上传目录 ---
# 本地开发：默认 public/uploads/，可通过 /api/uploads/ 访问
# UPLOAD_DIR="public/uploads"

# Railway 部署：必须设为容器内可写目录
# Railway 控制台：添加 Volume 挂载到 /app/uploads
# UPLOAD_DIR="/app/uploads"
