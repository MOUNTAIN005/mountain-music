{
  "build": {
    "builder": "nixpacks",
    "buildCommand": null,
    "watchPatterns": []
  },
  "deploy": {
    "startCommand": "node .next/standalone/server.js",
    "preDeployCommand": "node_modules/.bin/prisma db push --accept-data-loss && node_modules/.bin/prisma db seed",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
